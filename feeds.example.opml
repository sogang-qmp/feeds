<?xml version="1.0" encoding="UTF-8"?>

<opml version="1.0">
    <head>
        <title>Example Feed Subscriptions</title>
    </head>
    <body>
        <outline text="Journals" title="Journals">
            <outline type="rss" text="Nature" title="Nature" xmlUrl="http://www.nature.com/nature/current_issue/rss" htmlUrl="http://feeds.nature.com/nature/rss/current"/>
            <outline type="rss" text="Science Magazine" title="Science Magazine" xmlUrl="http://www.sciencemag.org/rss/current.xml" htmlUrl="https://www.science.org/journal/science"/>
            <outline type="rss" text="PRL" title="PRL" xmlUrl="http://feeds.aps.org/rss/recent/prl.xml" htmlUrl="http://journals.aps.org/prl/"/>
        </outline>
        <outline text="Blogs" title="Blogs">
            <outline type="rss" text="OpenAI Blog" title="OpenAI Blog" xmlUrl="https://openai.com/news/rss.xml" htmlUrl="https://openai.com/news"/>
        </outline>
    </body>
</opml>
